# Database
POSTGRES_PASSWORD=indra_secret
DATABASE_URL=postgresql+asyncpg://indra:indra_secret@localhost:5432/indra

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# OpenTelemetry
OTEL_ENDPOINT=http://localhost:4317

# CORS
CORS_ORIGINS=http://localhost:3333

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8333
NEXT_PUBLIC_WS_URL=ws://localhost:8333
